name: IntelliHire Pipeline

on:
  push:
    branches: [main, feature/InterviewFlow]
  pull_request:
    branches: ["**"]
  workflow_dispatch:

jobs:

  ai:
    name: AI Scripts (Python 3.11)
    runs-on: ubuntu-latest

    defaults:
      run:
        working-directory: IntelliHire_AI

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - run: python main.py > output.txt

      - uses: actions/upload-artifact@v4
        with:
          name: ai-output
          path: IntelliHire_AI/output.txt


  backend:
    name: Backend (Node / Express)
    runs-on: ubuntu-latest

    defaults:
      run:
        working-directory: IntelliHire.Server

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: 18

      - run: npm ci
      - run: node -v


  frontend:
    name: Frontend (React)
    runs-on: ubuntu-latest

    defaults:
      run:
        working-directory: IntelliHire.Client

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: 20

      - run: npm ci
      - run: npm run build

      - uses: actions/upload-artifact@v4
        with:
          name: react-build
          path: IntelliHire.Client/build

  deploy:
    name: Deployment (Vercel)
    runs-on: ubuntu-latest
    needs: [frontend, backend, ai]

    steps:
      - name: Deployment handled by Vercel
        run: echo "Vercel auto-deploys on push to develop/main"

      - name: Confirm deployment trigger
        run: echo "Deployment triggered via Vercel Git Integration"
